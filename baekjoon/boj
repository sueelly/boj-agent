#!/usr/bin/env bash
# ======================================
# boj — 백준 문제 풀이 CLI (어디서든 실행)
# ======================================
# 사용: boj run 4949 | boj commit 4949 | boj make 4949 | boj review 4949
# 설치: baekjoon/setup-boj-cli.sh 한 번 실행 (레포 경로 저장)
# ======================================

# BOJ_ROOT가 없으면 설치 시 저장한 경로 파일에서 로드 (Cursor 터미널 등 .zshrc 미로드 대응)
if [[ -z "$BOJ_ROOT" && -f "$HOME/.config/boj/root" ]]; then
  BOJ_ROOT="$(cat "$HOME/.config/boj/root")"
fi

# baekjoon 폴더 찾기: 위로 올라가며 template/Test.java 있는지 확인
find_baekjoon_root() {
  local dir
  dir="$(pwd)"
  while [[ -n "$dir" && "$dir" != "/" ]]; do
    if [[ -f "$dir/baekjoon/template/Test.java" ]]; then
      echo "$dir/baekjoon"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  if [[ -n "$BOJ_ROOT" ]]; then
    if [[ -f "$BOJ_ROOT/baekjoon/template/Test.java" ]]; then
      echo "$BOJ_ROOT/baekjoon"
      return 0
    fi
    if [[ -f "$BOJ_ROOT/template/Test.java" ]]; then
      echo "$BOJ_ROOT"
      return 0
    fi
  fi
  return 1
}

print_usage() {
  echo "사용법: boj <run|commit|make|review> [문제번호] [커밋메시지]"
  echo ""
  echo "  boj run 4949          — 테스트 실행"
  echo "  boj commit 4949 [msg] — 해당 문제 폴더 커밋"
  echo "  boj make 4949         — Cursor Agent CLI로 환경 생성 (또는 에디터+클립보드 안내)"
  echo "  boj review 4949       — Cursor Agent CLI로 리뷰 요청 (또는 에디터+클립보드 안내)"
  echo ""
  echo "설치: cd <algorithm>/baekjoon && ./setup-boj-cli.sh  (한 번만 실행, 레포 경로 저장)"
  echo "어디서든 쓰려면: 설치 시 BOJ_ROOT가 .zshrc에 추가됨"
}

ROOT=""
if ! ROOT="$(find_baekjoon_root)"; then
  echo "Error: baekjoon 폴더를 찾을 수 없습니다."
  echo "  이 터미널에 BOJ_ROOT가 없거나, 설치가 안 된 상태일 수 있습니다."
  echo "  해결: cd <algorithm>/baekjoon && ./setup-boj-cli.sh  (한 번만 실행)"
  echo "  또는: source ~/.zshrc 후 다시 시도"
  exit 1
fi

SUBCOMMAND="${1:-}"
PROBLEM_NUM="${2:-}"

case "$SUBCOMMAND" in
  run)
    if [[ -z "$PROBLEM_NUM" ]]; then
      echo "사용법: boj run [문제번호]"
      echo ""
      echo "존재하는 문제 폴더:"
      ls -d "$ROOT"/[0-9]*/ 2>/dev/null | sed 's|.*/||' | sed 's|/$||'
      exit 1
    fi
    PROBLEM_DIR=$(find "$ROOT" -maxdepth 1 -type d -name "${PROBLEM_NUM}*" | head -1)
    if [[ -z "$PROBLEM_DIR" || ! -d "$PROBLEM_DIR" ]]; then
      echo "Error: '${PROBLEM_NUM}'로 시작하는 폴더를 찾을 수 없습니다."
      ls -d "$ROOT"/[0-9]*/ 2>/dev/null | sed 's|.*/||' | sed 's|/$||'
      exit 1
    fi
    if [[ ! -f "$PROBLEM_DIR/test/Parse.java" ]] || [[ ! -f "$PROBLEM_DIR/test/test_cases.json" ]]; then
      echo "Error: $PROBLEM_DIR/test/Parse.java 또는 test/test_cases.json 이 없습니다."
      exit 1
    fi
    TEMPLATE="$ROOT/template"
    (cd "$PROBLEM_DIR" && javac -cp ".:$TEMPLATE" "$TEMPLATE/ParseAndCallSolve.java" "$TEMPLATE/Test.java" Solution.java test/Parse.java) && \
      (cd "$PROBLEM_DIR" && java -cp ".:test:$TEMPLATE" Test)
    (cd "$PROBLEM_DIR" && rm -f *.class test/*.class 2>/dev/null)
    ;;
  commit)
    if [[ -z "$PROBLEM_NUM" ]]; then
      echo "사용법: boj commit [문제번호] [커밋메시지(선택)]"
      exit 1
    fi
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    NC='\033[0m'
    PROBLEM_DIR=$(find "$ROOT" -maxdepth 1 -type d -name "${PROBLEM_NUM}*" | head -1)
    if [[ -z "$PROBLEM_DIR" || ! -d "$PROBLEM_DIR" ]]; then
      echo -e "${RED}Error: '${PROBLEM_NUM}'로 시작하는 폴더를 찾을 수 없습니다.${NC}"
      ls -d "$ROOT"/[0-9]*/ 2>/dev/null | sed 's|.*/||' | sed 's|/$||'
      exit 1
    fi
    PROBLEM_NAME=$(basename "$PROBLEM_DIR")
    shift 2
    COMMIT_MSG="${*:-$PROBLEM_NAME 풀이 완료}"
    echo -e "${BLUE}📁 문제 폴더: $PROBLEM_NAME${NC}"
    echo -e "${BLUE}💬 커밋 메시지: $COMMIT_MSG${NC}"
    echo ""
    echo -e "${YELLOW}📋 변경된 파일:${NC}"
    git -C "$ROOT" status --short "$PROBLEM_NAME"
    echo ""
    echo -e "${BLUE}➕ 파일 추가 중...${NC}"
    git -C "$ROOT" add "$PROBLEM_NAME/README.md" "$PROBLEM_NAME/Solution.java" \
      "$PROBLEM_NAME/test/Parse.java" "$PROBLEM_NAME/test/test_cases.json" \
      "$PROBLEM_NAME/submit/REVIEW.md" "$PROBLEM_NAME/submit/Submit.java" 2>/dev/null
    echo -e "${BLUE}📝 커밋 중...${NC}"
    if git -C "$ROOT" commit -m "$COMMIT_MSG"; then
      echo ""
      echo -e "${GREEN}✅ 커밋 완료!${NC}"
      echo ""
      read -p "GitHub에 푸시하시겠습니까? (y/N): " push_confirm
      if [[ "$push_confirm" =~ ^[Yy]$ ]]; then
        echo -e "${BLUE}🚀 푸시 중...${NC}"
        (cd "$ROOT" && git push) && echo -e "${GREEN}✅ 푸시 완료!${NC}" || echo -e "${RED}❌ 푸시 실패${NC}"
      else
        echo "푸시를 건너뛰었습니다. 나중에 'git push'로 푸시하세요."
      fi
    else
      echo -e "${YELLOW}⚠️ 커밋할 변경사항이 없거나 실패했습니다.${NC}"
    fi
    ;;
  make)
    if [[ -z "$PROBLEM_NUM" ]]; then
      echo "사용법: boj make [문제번호]"
      exit 1
    fi
    URL="https://www.acmicpc.net/problem/$PROBLEM_NUM"
    PROMPT="백준 ${PROBLEM_NUM}번 문제 풀이 환경 만들어줘. ${URL}"
    if command -v agent &>/dev/null; then
      echo "🔄 Cursor Agent CLI로 환경 생성 요청 중... (작업 디렉터리: $ROOT)"
      (cd "$ROOT" && agent chat -f -p -- "$PROMPT")
    else
      if command -v open &>/dev/null; then
        open "$URL"
      fi
      if command -v pbcopy &>/dev/null; then
        echo "$PROMPT" | pbcopy
        echo "📋 채팅에 붙여넣을 문구를 클립보드에 복사했습니다."
      fi
      if command -v cursor &>/dev/null; then
        cursor "$ROOT"
      elif command -v code &>/dev/null; then
        code "$ROOT"
      else
        echo "Cursor/VS Code CLI가 PATH에 없습니다. 수동으로 $ROOT 를 에디터로 열어주세요."
      fi
      echo ""
      echo "👉 Cursor가 baekjoon 폴더로 열렸습니다. 채팅에 붙여넣기하면 AI가 문제 폴더를 만든 뒤, 그 폴더를 루트로 다시 엽니다."
      echo "   Cursor Agent CLI 설치 시 채팅 없이 자동 실행: curl https://cursor.com/install -fsSL | bash"
      echo "   $PROMPT"
    fi
    ;;
  review)
    if [[ -z "$PROBLEM_NUM" ]]; then
      echo "사용법: boj review [문제번호]"
      exit 1
    fi
    PROBLEM_DIR=$(find "$ROOT" -maxdepth 1 -type d -name "${PROBLEM_NUM}*" | head -1)
    if [[ -z "$PROBLEM_DIR" || ! -d "$PROBLEM_DIR" ]]; then
      echo "Error: '${PROBLEM_NUM}'로 시작하는 문제 폴더가 없습니다."
      exit 1
    fi
    if command -v agent &>/dev/null; then
      echo "🔄 Cursor Agent CLI로 리뷰 요청 중... (작업 디렉터리: $PROBLEM_DIR)"
      (cd "$PROBLEM_DIR" && agent chat -f -p -- "리뷰해줘")
    else
      if command -v pbcopy &>/dev/null; then
        echo "리뷰해줘" | pbcopy
        echo "📋 '리뷰해줘' 를 클립보드에 복사했습니다."
      fi
      if command -v code &>/dev/null; then
        code "$PROBLEM_DIR"
      elif command -v cursor &>/dev/null; then
        cursor "$PROBLEM_DIR"
      else
        echo "VS Code/Cursor CLI가 PATH에 없습니다. 수동으로 $PROBLEM_DIR 를 에디터로 열어주세요."
      fi
      echo ""
      echo "👉 해당 문제 폴더를 VS Code로 열었습니다. 리뷰는 Cursor 채팅에서 '리뷰해줘' 요청하세요."
      echo "   Cursor Agent CLI 설치 시 채팅 없이 자동 실행: curl https://cursor.com/install -fsSL | bash"
    fi
    ;;
  -h|--help|help|"")
    print_usage
    ;;
  *)
    echo "Unknown subcommand: $SUBCOMMAND"
    print_usage
    exit 1
    ;;
esac
