#!/usr/bin/env bash
# ======================================
# boj — 백준 문제 풀이 CLI (어디서든 실행)
# ======================================
# 사용: boj run 4949 | boj commit 4949 | boj make 4949 | boj review 4949
# 설치: baekjoon/setup-boj-cli.sh 한 번 실행
# ======================================

# 현재 디렉터리에서 위로 올라가며 baekjoon/run.sh 가 있는 디렉터리 찾기
find_baekjoon_root() {
  local dir
  dir="$(pwd)"
  while [[ -n "$dir" && "$dir" != "/" ]]; do
    if [[ -f "$dir/baekjoon/run.sh" ]]; then
      echo "$dir/baekjoon"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  # fallback: 환경변수 (algorithm 루트 또는 baekjoon 경로)
  if [[ -n "$BOJ_ROOT" ]]; then
    if [[ -f "$BOJ_ROOT/baekjoon/run.sh" ]]; then
      echo "$BOJ_ROOT/baekjoon"
      return 0
    fi
    if [[ -f "$BOJ_ROOT/run.sh" ]]; then
      echo "$BOJ_ROOT"
      return 0
    fi
  fi
  return 1
}

print_usage() {
  echo "사용법: boj <run|commit|make|review> [문제번호] [커밋메시지]"
  echo ""
  echo "  boj run 4949          — 테스트 실행"
  echo "  boj commit 4949 [msg] — 해당 문제 폴더 커밋"
  echo "  boj make 4949         — Cursor Agent CLI로 환경 생성 (또는 에디터+클립보드 안내)"
  echo "  boj review 4949       — Cursor Agent CLI로 리뷰 요청 (또는 에디터+클립보드 안내)"
  echo ""
  echo "설치: baekjoon 폴더에서 ./setup-boj-cli.sh 실행 후, PATH에 ~/bin 포함되어 있어야 함."
  echo "어디서든 쓰려면: .zshrc에 export BOJ_ROOT=~/Programming/algorithm 추가 (또는 설치 시 자동 추가)"
}

ROOT=""
if ! ROOT="$(find_baekjoon_root)"; then
  echo "Error: baekjoon 폴더를 찾을 수 없습니다."
  echo "  - algorithm 폴더 아래에서 실행하거나"
  echo "  - .zshrc에 export BOJ_ROOT=~/Programming/algorithm 를 설정하세요."
  echo "  설치: cd <algorithm>/baekjoon && ./setup-boj-cli.sh"
  exit 1
fi

SUBCOMMAND="${1:-}"
PROBLEM_NUM="${2:-}"

case "$SUBCOMMAND" in
  run)
    if [[ -z "$PROBLEM_NUM" ]]; then
      echo "사용법: boj run [문제번호]"
      exit 1
    fi
    "$ROOT/run.sh" "$PROBLEM_NUM"
    ;;
  commit)
    if [[ -z "$PROBLEM_NUM" ]]; then
      echo "사용법: boj commit [문제번호] [커밋메시지(선택)]"
      exit 1
    fi
    shift 2
    "$ROOT/commit.sh" "$PROBLEM_NUM" "$@"
    ;;
  make)
    if [[ -z "$PROBLEM_NUM" ]]; then
      echo "사용법: boj make [문제번호]"
      exit 1
    fi
    URL="https://www.acmicpc.net/problem/$PROBLEM_NUM"
    PROMPT="백준 ${PROBLEM_NUM}번 문제 풀이 환경 만들어줘. ${URL}"
    if command -v agent &>/dev/null; then
      echo "🔄 Cursor Agent CLI로 환경 생성 요청 중... (작업 디렉터리: $ROOT)"
      (cd "$ROOT" && agent chat -f -p -- "$PROMPT")
    else
      if command -v open &>/dev/null; then
        open "$URL"
      fi
      if command -v pbcopy &>/dev/null; then
        echo "$PROMPT" | pbcopy
        echo "📋 채팅에 붙여넣을 문구를 클립보드에 복사했습니다."
      fi
      # CLI 없을 때: 문제 폴더는 아직 없으므로 baekjoon만 연다. 채팅에 붙여넣으면 AI가 폴더 생성 후 해당 폴더를 루트로 연다.
      if command -v cursor &>/dev/null; then
        cursor "$ROOT"
      elif command -v code &>/dev/null; then
        code "$ROOT"
      else
        echo "Cursor/VS Code CLI가 PATH에 없습니다. 수동으로 $ROOT 를 에디터로 열어주세요."
      fi
      echo ""
      echo "👉 Cursor가 baekjoon 폴더로 열렸습니다. 채팅에 붙여넣기하면 AI가 문제 폴더를 만든 뒤, 그 폴더를 루트로 다시 엽니다."
      echo "   Cursor Agent CLI 설치 시 채팅 없이 자동 실행: curl https://cursor.com/install -fsSL | bash"
      echo "   $PROMPT"
    fi
    ;;
  review)
    if [[ -z "$PROBLEM_NUM" ]]; then
      echo "사용법: boj review [문제번호]"
      exit 1
    fi
    PROBLEM_DIR=$(find "$ROOT" -maxdepth 1 -type d -name "${PROBLEM_NUM}*" | head -1)
    if [[ -z "$PROBLEM_DIR" || ! -d "$PROBLEM_DIR" ]]; then
      echo "Error: '${PROBLEM_NUM}'로 시작하는 문제 폴더가 없습니다."
      exit 1
    fi
    if command -v agent &>/dev/null; then
      echo "🔄 Cursor Agent CLI로 리뷰 요청 중... (작업 디렉터리: $PROBLEM_DIR)"
      (cd "$PROBLEM_DIR" && agent chat -f -p -- "리뷰해줘")
    else
      if command -v pbcopy &>/dev/null; then
        echo "리뷰해줘" | pbcopy
        echo "📋 '리뷰해줘' 를 클립보드에 복사했습니다."
      fi
      # CLI 없을 때: 문제 폴더는 무조건 code . 로 연다 (풀 때 AI 없어야 하므로).
      if command -v code &>/dev/null; then
        code "$PROBLEM_DIR"
      elif command -v cursor &>/dev/null; then
        cursor "$PROBLEM_DIR"
      else
        echo "VS Code/Cursor CLI가 PATH에 없습니다. 수동으로 $PROBLEM_DIR 를 에디터로 열어주세요."
      fi
      echo ""
      echo "👉 해당 문제 폴더를 VS Code로 열었습니다. 리뷰는 Cursor 채팅에서 '리뷰해줘' 요청하세요."
      echo "   Cursor Agent CLI 설치 시 채팅 없이 자동 실행: curl https://cursor.com/install -fsSL | bash"
    fi
    ;;
  -h|--help|help|"")
    print_usage
    ;;
  *)
    echo "Unknown subcommand: $SUBCOMMAND"
    print_usage
    exit 1
    ;;
esac
