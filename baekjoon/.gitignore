# 모든 파일 무시
*

# 허용할 파일들
!.gitignore
!README.md
!DEVLOG.md
!commit.sh
!run.sh
!.cursorrules

# 각 문제 폴더에서 허용할 파일들
!*/
!*/README.md
!*/Solution.java

# test 폴더 (Parse + test_cases — 커밋하여 테스트 재현 가능)
!*/test/
!*/test/Parse.java
!*/test/test_cases.json

# submit 폴더 허용
!*/submit/
!*/submit/REVIEW.md
!*/submit/Submit.java

# template 폴더는 전체 허용
!template/
!template/**

# 컴파일된 파일 무시
*.class

# IDE 설정 무시
.vscode/
.project
.classpath
