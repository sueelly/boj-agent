  "languages": {
    "java": {
      "name": "Java 11",
      "extension": "java",
      "compile": "javac -cp .:$TEMPLATE $TEMPLATE/ParseAndCallSolve.java $TEMPLATE/Test.java Solution.java test/Parse.java",
      "run": "java -cp .:test:$TEMPLATE Test",
      "template_dir": "java",
      "skeleton": {
        "solution": "Solution.java",
        "parse": "test/Parse.java",
        "submit": "submit/Submit.java"
      },
      "submit_class": "Main",
      "boj_lang_id": 28,
      "notes": "Java 11 (OpenJDK). BOJ 채점 서버 기준."
    },
    "python": {
